---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Nestled — Everything you need to live in a tiny home",
  description = "Honest guides on tiny home zoning, financing, builders, and costs — so you can make the move with confidence."
} = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Nestled",
      "description": "Your guide to living small, living well. Practical, honest information for every stage of the tiny home journey.",
      "url": "https://nestled.onrender.com"
    }
    </script>
  </head>
  <body class="min-h-screen flex flex-col font-body antialiased" style="background-color: oklch(0.97 0.015 75); color: oklch(0.20 0.018 75);">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
